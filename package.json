{
  "name": "notebook-app",
  "version": "0.0.0",
  "private": true,
  "description": "Accessibility-first note-taking app for academics",
  "license": "AGPL-3.0-or-later",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "test:unit": "node --test \"scripts/**/*.test.mjs\"",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:css": "stylelint \"**/*.css\" --cache --cache-location node_modules/.cache/stylelint/",
    "lint:css:fix": "stylelint \"**/*.css\" --fix --cache --cache-location node_modules/.cache/stylelint/",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "audit:fallow": "fallow audit",
    "package": "electron-vite build && electron-builder --dir",
    "dist": "electron-vite build && electron-builder",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test-storybook": "vitest --project=storybook --run",
    "prepare": "node scripts/prepare.mjs"
  },
  "packageManager": "pnpm@11.1.1",
  "engines": {
    "node": ">=24",
    "pnpm": ">=11"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@double-great/stylelint-a11y": "^3.4.14",
    "@eslint/js": "^9.39.4",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.60.0",
    "@storybook/addon-a11y": "^10.4.1",
    "@storybook/addon-docs": "^10.4.1",
    "@storybook/addon-mcp": "^0.6.0",
    "@storybook/addon-vitest": "^10.4.1",
    "@storybook/react-vite": "^10.4.1",
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitest/browser-playwright": "^4.1.7",
    "@vitest/coverage-v8": "^4.1.7",
    "electron": "^42.2.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-storybook": "^10.4.1",
    "fallow": "^2.80.0",
    "husky": "9.1.7",
    "license-checker": "^25.0.1",
    "lint-staged": "17.0.5",
    "playwright": "^1.60.0",
    "prettier": "3.8.3",
    "semver": "^7.8.1",
    "storybook": "^10.4.1",
    "storybook-design-token": "^5.0.0",
    "stylelint": "^17.12.0",
    "stylelint-config-clean-order": "^10.0.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-declaration-strict-value": "^1.11.1",
    "stylelint-order": "^8.1.1",
    "stylelint-plugin-logical-css": "^2.1.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4",
    "vite": "^7.0.0",
    "vitest": "^4.1.7",
    "yaml": "^2.9.0"
  },
  "dependencies": {
    "@ark-ui/react": "^5.37.0",
    "@hashicorp/design-system-tokens": "^5.0.0",
    "effect": "^3.21.2",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.css": [
      "stylelint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml,html}": [
      "prettier --write"
    ]
  }
}
