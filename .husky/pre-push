# Mirrors CI gates. Ordered cheap -> expensive so failures surface fast.
# Bypass: `git push --no-verify` or `HUSKY=0 git push`.

pnpm lint || exit 1

pnpm format:check || exit 1

pnpm typecheck || exit 1

pnpm exec license-checker \
  --production \
  --excludePrivatePackages \
  --onlyAllow "MIT;ISC;Apache-2.0;BSD-2-Clause;BSD-3-Clause;0BSD;BSD;MPL-2.0;BlueOak-1.0.0;CC0-1.0;CC-BY-4.0;Unlicense;Python-2.0;Zlib;AGPL-3.0-or-later;AGPL-3.0-only;GPL-3.0-or-later;GPL-3.0-only;LGPL-3.0-or-later" || exit 1

# Prod-reachable advisories block (mirror CI). DevDep findings are
# advisory-only — surfaced as a stderr notice but don't fail the push.
pnpm audit --prod --audit-level high || exit 1
pnpm audit --audit-level high || echo "pre-push: devDep advisories found (non-blocking); see output above." >&2

if git rev-parse --verify --quiet origin/main >/dev/null; then
  pnpm audit:fallow --base origin/main || exit 1
else
  pnpm audit:fallow || exit 1
fi

pnpm build || exit 1

pnpm test-storybook || exit 1
