# Mirrors CI gates. Ordered cheap -> expensive so failures surface fast.
# Bypass: `git push --no-verify` or `HUSKY=0 git push`.

set -e

npm run typecheck

npx license-checker \
  --production \
  --excludePrivatePackages \
  --onlyAllow "MIT;ISC;Apache-2.0;BSD-2-Clause;BSD-3-Clause;0BSD;BSD;MPL-2.0;BlueOak-1.0.0;CC0-1.0;CC-BY-4.0;Unlicense;Python-2.0;Zlib;AGPL-3.0-or-later;AGPL-3.0-only;GPL-3.0-or-later;GPL-3.0-only;LGPL-3.0-or-later"

npm audit --audit-level=high

if git rev-parse --verify --quiet origin/main >/dev/null; then
  npm run audit:fallow -- --base origin/main
else
  npm run audit:fallow
fi

npm run build

npm run test-storybook
