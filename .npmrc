# pnpm config. Default strict (isolated) node_modules layout is kept on
# purpose — it surfaces phantom-dependency bugs that npm's flat tree hides.
# See docs/features/continuous-integration/adrs/package-manager.md.

# Enforce the engines field in package.json (node >=24, pnpm >=11) so a
# mismatched toolchain fails loudly at install instead of producing a
# subtly-different tree.
engine-strict=true
